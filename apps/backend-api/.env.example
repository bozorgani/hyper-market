PORT=3000
APP_ENV=development
DATABASE_URL=mongodb://localhost:27017/hyper_market
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_ACCESS_SECRET=change_access_secret_in_production
JWT_REFRESH_SECRET=change_refresh_secret_in_production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
JWT_ISSUER=hyper-market
JWT_AUDIENCE=hyper-market-api
OTP_HASH_SECRET=change_otp_hash_secret_in_production
AUTH_COOKIE_SAME_SITE=lax
AUTH_RETURN_TOKENS_IN_BODY=false
AUTH_LOG_OTP_CODES=true
CSRF_PROTECTION_ENABLED=true
ANALYTICS_MAX_METADATA_BYTES=4096
SEARCH_INDEXING_WORKER_ENABLED=true
IDEMPOTENCY_KEY_TTL_SECONDS=86400
MONGODB_TRANSACTION_FALLBACK_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Database Migrations ────────────────────────────────────────────────────────
# Set to 'true' to skip running migrations on startup (e.g. in worker processes).
SKIP_MIGRATIONS=false

# Durable event bus / outbox relay
OUTBOX_RELAY_ENABLED=true

# Worker process isolation: set WORKERS_ENABLED=false in the main API process
# and WORKERS_ENABLED=true in the dedicated worker process.
WORKERS_ENABLED=true
OUTBOX_SWEEP_INTERVAL_MS=5000
OUTBOX_PENDING_GRACE_MS=15000
OUTBOX_RELAY_MAX_ATTEMPTS=5

# Swagger / OpenAPI docs (mounted at /api/docs). Disabled in production
# unless explicitly opted in with SWAGGER_ENABLED=true.
SWAGGER_ENABLED=false

# SMS.ir — OTP delivery via SMS (requires active account with credit)
SMS_IR_API_KEY=
SMS_IR_BASE_URL=https://api.sms.ir/v1
SMS_IR_VERIFY_TEMPLATE_ID=123456
SMS_IR_VERIFY_PARAMETER_NAME=Code

# SMTP — OTP delivery via email (nodemailer)
# When these are set, OTP emails are sent through your SMTP provider.
# When left empty, OTP emails are logged to the console only (dev mode).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=هایپرمارکت
SMTP_FROM_ADDRESS=noreply@hypermarket.ir

# Meilisearch
MEILI_HOST=http://localhost:7700
MEILI_API_KEY=

PUBLIC_API_BASE_URL=http://localhost:3001

# ── Product Image Storage ──────────────────────────────────────────────────────
# STORAGE_DRIVER=local    → save to local filesystem (default)
# STORAGE_DRIVER=s3       → upload to S3-compatible bucket (requires @aws-sdk/client-s3)
STORAGE_DRIVER=local
PRODUCT_IMAGE_UPLOAD_DIR=./uploads/product-images
PRODUCT_IMAGE_MAX_BYTES=5242880

# ── S3 Storage (only used when STORAGE_DRIVER=s3) ─────────────────────────────
# S3_ENDPOINT=             # Custom endpoint (e.g. MinIO). Omit for AWS S3.
# S3_REGION=us-east-1
# S3_BUCKET=my-product-images
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL=           # Base URL for public image access.
                           # Default: https://{bucket}.s3.{region}.amazonaws.com

# Coupons — JSON array of {code, percent, active, minSubtotal, maxDiscountAmount, startsAt, endsAt}
COUPON_CODES_JSON=[]

# Observability / error tracking
ERROR_TRACKING_WEBHOOK_URL=

# ── FILE-based secrets (Docker/Kubernetes secrets) ───────────────────────────
# Any sensitive variable below may be supplied via KEY_FILE instead of KEY.
# Explicit KEY wins over KEY_FILE. Mounted file contents are trimmed.
# DATABASE_URL_FILE=/run/secrets/database_url
# REDIS_URL_FILE=/run/secrets/redis_url
# JWT_ACCESS_SECRET_FILE=/run/secrets/jwt_access_secret
# JWT_REFRESH_SECRET_FILE=/run/secrets/jwt_refresh_secret
# PASSWORD_PEPPER_FILE=/run/secrets/password_pepper
# OTP_HASH_SECRET_FILE=/run/secrets/otp_hash_secret
# MEILI_API_KEY_FILE=/run/secrets/meili_api_key
# SMTP_PASS_FILE=/run/secrets/smtp_pass
# SMS_IR_API_KEY_FILE=/run/secrets/sms_ir_api_key
# S3_SECRET_ACCESS_KEY_FILE=/run/secrets/s3_secret_access_key
# ERROR_TRACKING_WEBHOOK_URL_FILE=/run/secrets/error_tracking_webhook_url
# COUPON_CODES_JSON_FILE=/run/secrets/coupon_codes_json
# SHIPPING_CONFIG_JSON_FILE=/run/secrets/shipping_config_json

# ── Rate limiting (only enabled when APP_ENV=production) ─────────────────────
RATE_LIMIT_DEFAULT_LIMIT=1000
RATE_LIMIT_DEFAULT_TTL_MS=60000
RATE_LIMIT_AUTH_LIMIT=30
RATE_LIMIT_AUTH_TTL_MS=60000
RATE_LIMIT_SENSITIVE_LIMIT=100
RATE_LIMIT_SENSITIVE_TTL_MS=60000
