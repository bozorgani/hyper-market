PORT=3000
APP_ENV=development
DATABASE_URL=mongodb://localhost:27017/hyper_market
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_ACCESS_SECRET=change_access_secret_in_production
JWT_REFRESH_SECRET=change_refresh_secret_in_production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
JWT_ISSUER=hyper-market
JWT_AUDIENCE=hyper-market-api
AUTH_COOKIE_SAME_SITE=lax
AUTH_RETURN_TOKENS_IN_BODY=false
AUTH_LOG_OTP_CODES=true
CSRF_PROTECTION_ENABLED=true
ANALYTICS_MAX_METADATA_BYTES=4096
SEARCH_INDEXING_WORKER_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
SMS_IR_API_KEY=change_sms_ir_api_key
SMS_IR_BASE_URL=https://api.sms.ir/v1
SMS_IR_VERIFY_TEMPLATE_ID=123456
SMS_IR_VERIFY_PARAMETER_NAME=Code
