# Hyper Market web environment contract
#
# This file contains public/non-secret configuration examples only.
# Never put JWT secrets, passwords, API keys, or tokens in NEXT_PUBLIC_* variables.
# NEXT_PUBLIC_* values are embedded into the browser bundle at build time.

# Browser-reachable API base URL, including the backend API prefix.
# Local:      http://localhost:3001/api/v1
# Production: https://api.example.com/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1

# Public canonical origin used by metadata, canonical URLs, robots, sitemap,
# Open Graph URLs, and structured data.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only API URL used by Server Components and Server Actions.
# In Docker this should normally be the internal backend service URL.
# Example Docker value: http://backend:3001/api/v1
SERVER_API_BASE_URL=http://localhost:3001/api/v1

# Optional server-side fallback used by server-api.ts/backend actions.
# Prefer SERVER_API_BASE_URL when the web server has an internal API route.
PUBLIC_API_BASE_URL=http://localhost:3001/api/v1

# Content-Security-Policy mode.
# report-only is useful during rollout; enforce is required after violations
# have been reviewed before production traffic is enabled.
CSP_MODE=report-only

# CSP report destination. A relative same-origin path is recommended.
CSP_REPORT_ENDPOINT=/api/csp-report

# Optional comma-separated allowlist for external redirect domains.
# Relative same-origin redirects do not require this value.
ALLOWED_REDIRECT_DOMAINS=

# Test-only switch. Keep disabled/unset outside Playwright E2E runs.
PLAYWRIGHT_MOCK_ACTIONS=0
