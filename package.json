{
  "name": "hyper-market",
  "version": "1.0.0",
  "private": true,
  "description": "Hyper Market enterprise e-commerce monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "install:all": "npm install",
    "backend:dev": "npm run start:dev --workspace=apps/backend-api",
    "backend:build": "npm run build --workspace=apps/backend-api",
    "backend:test": "npm run test --workspace=apps/backend-api",
    "sync:state": "node scripts/sync-project-state.js",
    "prepare": "if [ -d .git ]; then husky; fi",
    "search:reindex": "node scripts/reindex-products-search.js",
    "seed:products": "node scripts/seed-products.js",
    "seed:permissions": "node scripts/seed-permissions.js",
    "seed:admin": "node scripts/seed-admin.js",
    "seed:all": "node scripts/seed-all.js",
    "e2e:infra:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "e2e:infra:down": "docker compose -f docker-compose.test.yml down -v --remove-orphans",
    "backend:test:e2e": "npm run test:e2e --workspace=apps/backend-api -- --runInBand",
    "web:e2e": "npx playwright test --config apps/web/playwright.config.ts",
    "web:e2e:fullstack": "npx playwright test --config apps/web/playwright.fullstack.config.ts",
    "web:e2e:headed": "npx playwright test --config apps/web/playwright.config.ts --headed"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  },
  "overrides": {
    "multer": "2.2.0",
    "postcss": "8.5.16",
    "eslint": {
      "minimatch": {
        "brace-expansion": "1.1.16"
      }
    },
    "@nestjs/cli": {
      "minimatch": {
        "brace-expansion": "5.0.7"
      }
    },
    "typescript-eslint": {
      "minimatch": {
        "brace-expansion": "5.0.7"
      }
    },
    "jest": {
      "minimatch": {
        "brace-expansion": "2.1.2"
      }
    }
  }
}
